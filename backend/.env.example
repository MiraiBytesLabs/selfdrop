# ── SelfDrop Backend — Environment Variables ───────────────
#
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically on startup.
#
#   cp .env.example .env
#
# When running via Docker, set these in docker-compose.yml
# under the `environment:` key instead — the .env file is
# only used when running Node directly outside of Docker.

# ── Required ───────────────────────────────────────────────

# Secret key used to sign session tokens.
# Generate one with: openssl rand -hex 32
# Never commit this value. Change it before deploying.
SESSION_SECRET=change-me-to-a-long-random-string

# ── File serving ───────────────────────────────────────────

# Absolute path to the root directory SelfDrop serves files from.
# All shares must reference files within this directory.
FILES_ROOT=/data/files

# How files are sent to clients:
#   x-accel-redirect — Nginx serves files directly (best performance, default)
#   stream           — Node streams files (required for Traefik, Caddy, or no Nginx)
SENDFILE_MODE=x-accel-redirect

# ── Database ───────────────────────────────────────────────

# Path to the SQLite database file.
# The directory must exist and be writable by the Node process.
DB_PATH=/data/db/selfdrop.db

# ── Server ─────────────────────────────────────────────────

# Port the Node.js server listens on.
PORT=3000

# Proxy mode:
#   internal — embedded Nginx handles requests and proxies to Node (default)
#   external — Node listens directly, use your own reverse proxy
PROXY_MODE=internal

# ── Sessions ───────────────────────────────────────────────

# Token lifetime:
#   persistent — tokens last 90 days (default)
#   session    — tokens expire when the browser is closed
SESSION_MODE=persistent

# ── ZIP downloads ──────────────────────────────────────────

# Maximum total size of files that can be zipped in a single request (bytes).
# Default: 10 GB
ZIP_MAX_BYTES=10737418240

# Directory where temporary ZIP files are written before serving.
# Must be writable. Files are cleaned up automatically.
ZIP_TEMP_DIR=/tmp/selfdrop-zips

# ── Preview ────────────────────────────────────────────────

# Maximum file size eligible for in-browser preview (bytes).
# Default: 200 MB
PREVIEW_MAX_BYTES=209715200
