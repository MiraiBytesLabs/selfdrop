{
  "name": "selfdrop-backend",
  "version": "0.1.0",
  "description": "SelfDrop — Share files directly from your own server.",
  "type": "module",
  "main": "src/app.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
